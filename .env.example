# ============================================================================
# OrionFlow_CAD Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in your values.
# Never commit the actual .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Configuration (Required for CAD generation)
# ----------------------------------------------------------------------------

# Groq API Key (Primary LLM Provider)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Alternative provider - optional)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Provider Selection: "groq" | "openai" | "local"
# Default: groq
LLM_PROVIDER=groq

# LLM Model Name (for Groq)
# Default: llama-3.3-70b-versatile
LLM_MODEL=llama-3.3-70b-versatile

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
# Default: 0.1 (low for structured CAD output)
LLM_TEMPERATURE=0.1

# Maximum tokens for LLM response
# Default: 2048
LLM_MAX_TOKENS=2048

# ----------------------------------------------------------------------------
# CAD Generation Settings
# ----------------------------------------------------------------------------

# Output directory for generated files (STEP, STL, GLB)
# Default: outputs
OUTPUT_DIR=outputs

# Maximum LLM retry attempts on compilation failure
# Default: 1
MAX_LLM_RETRIES=1

# Enable V3 compiler with topological identity tracking
# Default: false
USE_V3_COMPILER=false

# Enable two-stage LLM pipeline (Intent → Template)
# Default: false
USE_TWO_STAGE_PIPELINE=false

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------

# FastAPI server host
# Default: 127.0.0.1
API_HOST=127.0.0.1

# FastAPI server port
# Default: 8000
API_PORT=8000

# CORS allowed origins (comma-separated)
# Default: http://localhost:5173 (Vite dev server)
CORS_ORIGINS=http://localhost:5173

# Enable debug mode (verbose logging)
# Default: false
DEBUG=false

# ----------------------------------------------------------------------------
# Onshape Integration (Optional - Cloud CAD Sync)
# ----------------------------------------------------------------------------
# If configured, generated CAD will sync to Onshape cloud workspace.
# Leave empty to disable Onshape integration.

# Onshape Document ID
ONSHAPE_DOC_ID=

# Onshape Workspace ID
ONSHAPE_WORKSPACE_ID=

# Onshape Element ID (FeatureStudio)
ONSHAPE_ELEMENT_ID=

# Onshape API Access Key
ONSHAPE_ACCESS_KEY=

# Onshape API Secret Key
ONSHAPE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Dataset & Logging
# ----------------------------------------------------------------------------

# Dataset storage directory for training samples
# Default: data
DATASET_DIR=data

# Feedback log file path
# Default: data/feedback.jsonl
FEEDBACK_LOG_PATH=data/feedback.jsonl

# Enable dataset sample logging
# Default: true
ENABLE_DATASET_LOGGING=true

# Log level: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=INFO
