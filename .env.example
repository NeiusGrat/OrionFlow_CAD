# ============================================================================
# OrionFlow_CAD Environment Configuration
# ============================================================================
# Copy this file to `.env` and fill in your values.
# Never commit the actual .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=OrionFlow CAD
APP_VERSION=0.3.0
ENVIRONMENT=development

# ----------------------------------------------------------------------------
# LLM Configuration (Required for CAD generation)
# ----------------------------------------------------------------------------

# Groq API Key (Primary LLM Provider)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Alternative provider - optional)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Provider Selection: "groq" | "openai" | "local"
LLM_PROVIDER=groq

# LLM Model Name
LLM_MODEL=llama-3.3-70b-versatile

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# Maximum tokens for LLM response
LLM_MAX_TOKENS=2048

# ----------------------------------------------------------------------------
# CAD Generation Settings
# ----------------------------------------------------------------------------

# Output directory for generated files (STEP, STL, GLB)
OUTPUT_DIR=outputs

# Maximum LLM retry attempts on compilation failure
MAX_LLM_RETRIES=1

# Enable V3 compiler with topological identity tracking
USE_V3_COMPILER=false

# Enable two-stage LLM pipeline (Intent -> Template)
USE_TWO_STAGE_PIPELINE=false

# OFL (OrionFlow Language) Code Generation
OFL_LLM_PROVIDER=groq
OFL_GROQ_MODEL=llama-3.3-70b-versatile
# OFL_LOCAL_MODEL_PATH=  # Set when fine-tuned model is ready

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------

# FastAPI server host (use 0.0.0.0 for Docker)
API_HOST=0.0.0.0

# FastAPI server port
API_PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Enable debug mode (verbose logging)
DEBUG=false

# Frontend URL for redirects
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=orionflow
DB_PASSWORD=orionflow
DB_NAME=orionflow
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ----------------------------------------------------------------------------
# Redis (Caching & Task Queue)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----------------------------------------------------------------------------
# Celery (Async Workers)
# ----------------------------------------------------------------------------
# Defaults to Redis URL if not set
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_WORKER_CONCURRENCY=4

# ----------------------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------------------
# IMPORTANT: Change in production!
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------------------------
# Stripe (Billing - Optional)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Free tier limits
FREE_TIER_GENERATIONS=10
FREE_TIER_MAX_DESIGNS=5

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_GENERATION=10/minute

# ----------------------------------------------------------------------------
# Sentry (Error Tracking - Optional)
# ----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# ----------------------------------------------------------------------------
# AWS S3 (File Storage - Optional)
# ----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ----------------------------------------------------------------------------
# Email (SMTP - Optional)
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@orionflow.dev
SMTP_FROM_NAME=OrionFlow

# ----------------------------------------------------------------------------
# Onshape Integration (Optional - Cloud CAD Sync)
# ----------------------------------------------------------------------------
ONSHAPE_DOC_ID=
ONSHAPE_WORKSPACE_ID=
ONSHAPE_ELEMENT_ID=
ONSHAPE_ACCESS_KEY=
ONSHAPE_SECRET_KEY=

# ----------------------------------------------------------------------------
# Dataset & Logging
# ----------------------------------------------------------------------------
DATASET_DIR=data
FEEDBACK_LOG_PATH=data/feedback.jsonl
ENABLE_DATASET_LOGGING=true
LOG_LEVEL=INFO
LOG_FORMAT=json
