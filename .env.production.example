# ============================================================================
# OrionFlow — BACKEND production env (FastAPI on Fly.io / Render / Koyeb)
# Copy to your host's secret manager. Do NOT commit the filled-in version.
# ============================================================================

# --- App ---
ENVIRONMENT=production
DEBUG=false
APP_VERSION=0.3.0

# --- LLM (Groq free tier — launch model) ---
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile
OFL_LLM_PROVIDER=groq
OFL_GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS / frontend (your domain) ---
CORS_ORIGINS=https://orionflow.in,https://www.orionflow.in,https://app.orionflow.in
FRONTEND_URL=https://app.orionflow.in

# --- Database (Supabase — use the DIRECT connection, port 5432) ---
# Supabase: Project Settings -> Database -> Connection info
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_NAME=postgres
# NOTE: Supabase requires SSL. If asyncpg can't connect, see runbook step 4
#       (add ssl to the engine connect_args).

# --- Redis (Upstash free — or remove if not running Celery) ---
REDIS_HOST=your-instance.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_password
REDIS_DB=0

# --- Auth ---
# Generate once:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_long_random_string

# --- Email (Hostinger Starter Business Email) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@orionflow.in
SMTP_PASSWORD=your_mailbox_password
SMTP_FROM_EMAIL=hello@orionflow.in
SMTP_FROM_NAME=OrionFlow

# --- Limits ---
FREE_TIER_GENERATIONS=10
RATE_LIMIT_GENERATION=10/minute
LOG_LEVEL=INFO
LOG_FORMAT=json
