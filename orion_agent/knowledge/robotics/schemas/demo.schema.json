{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrionFlow Robotics Demonstration Assemblies",
  "type": "object",
  "required": ["schema_version", "package", "version", "demos"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "package": {"type": "string"},
    "version": {"type": "string"},
    "demos": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/demo"}}
  },
  "additionalProperties": false,
  "$defs": {
    "status": {"enum": ["source_specific", "candidate", "illustrative"]},
    "node": {
      "type": "object",
      "required": ["id", "component_ref", "role"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
        "component_ref": {"type": "string"},
        "role": {"type": "string"},
        "quantity": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "relation", "interface_ref"],
      "properties": {
        "from": {"type": "string"},
        "to": {"type": "string"},
        "relation": {"type": "string"},
        "interface_ref": {"type": "string"}
      },
      "additionalProperties": false
    },
    "joint": {
      "type": "object",
      "required": ["id", "type", "parent_node", "child_node", "axis", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
        "type": {"enum": ["fixed", "revolute", "prismatic", "mimic"]},
        "parent_node": {"type": "string"},
        "child_node": {"type": "string"},
        "axis": {"type": "string"},
        "status": {"$ref": "#/$defs/status"},
        "note": {"type": "string"}
      },
      "additionalProperties": false
    },
    "demo": {
      "type": "object",
      "required": ["id", "title", "data_status", "maturity", "summary", "sources", "assembly_graph", "kinematic_model", "required_inputs", "verification_gates", "exports", "agent_guidance"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_.-]+$"},
        "title": {"type": "string"},
        "data_status": {"$ref": "#/$defs/status"},
        "maturity": {"enum": ["concept_demo", "engineering_prototype", "release_candidate", "released"]},
        "summary": {"type": "string"},
        "sources": {"type": "array", "items": {"type": "string"}},
        "assembly_graph": {
          "type": "object",
          "required": ["nodes", "edges"],
          "properties": {
            "nodes": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/node"}},
            "edges": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/edge"}}
          },
          "additionalProperties": false
        },
        "kinematic_model": {"type": "array", "items": {"$ref": "#/$defs/joint"}},
        "required_inputs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "verification_gates": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "exports": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "agent_guidance": {"type": "string"}
      },
      "additionalProperties": false
    }
  }
}
