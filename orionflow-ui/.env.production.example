# Frontend build-time config. Set this in Vercel project settings, OR create
# orionflow-ui/.env.production before `npm run build` if hosting on Hostinger.
VITE_API_URL=https://sahilmaniyar57--orionflow-api-api.modal.run

# Google OAuth client ID (Web application) from console.cloud.google.com.
# The "Sign in with Google" button is hidden when this is unset. The same
# value must be set as GOOGLE_CLIENT_ID in the Modal secret (backend).
VITE_GOOGLE_CLIENT_ID=
